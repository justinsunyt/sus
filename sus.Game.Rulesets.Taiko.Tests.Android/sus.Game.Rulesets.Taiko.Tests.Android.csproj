<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="..\sus.Android.props" />
  <PropertyGroup>
    <TargetFramework>net8.0-android</TargetFramework>
    <OutputType>Exe</OutputType>
    <RootNamespace>sus.Game.Rulesets.Taiko.Tests</RootNamespace>
    <AssemblyName>sus.Game.Rulesets.Taiko.Tests.Android</AssemblyName>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="..\sus.Game.Rulesets.Taiko.Tests\**\*.cs" Exclude="**\obj\**">
      <Link>%(RecursiveDir)%(Filename)%(Extension)</Link>
    </Compile>
    <!-- TargetPath is relative to RootNamespace,
         and DllResourceStore is relative to AssemblyName. -->
    <EmbeddedResource Include="..\sus.Game.Rulesets.Taiko.Tests\**\Resources\**\*">
      <Link>%(RecursiveDir)%(Filename)%(Extension)</Link>
      <TargetPath>Android\%(RecursiveDir)%(Filename)%(Extension)</TargetPath>
    </EmbeddedResource>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\sus.Game.Rulesets.Taiko\sus.Game.Rulesets.Taiko.csproj" />
    <ProjectReference Include="..\sus.Game.Tests\sus.Game.Tests.csproj" />
    <ProjectReference Include="..\sus.Game\sus.Game.csproj" />
  </ItemGroup>
</Project>
